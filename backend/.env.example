# ============================================
# Grocy-Mart Backend Configuration
# ============================================
# IMPORTANT: Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# Server
PORT=2005

# Database
# Generate strong password: openssl rand -base64 32
DATABASE_URL=postgresql://username:STRONG_PASSWORD@localhost:5432/foodapp

# JWT Security
# IMPORTANT: Generate a strong secret using:
#   openssl rand -hex 64
# Never use example values in production!
JWT_SECRET=REPLACE_WITH_64_CHAR_HEX_SECRET_GENERATED_BY_OPENSSL
JWT_EXPIRES_IN=24h

# Environment
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# ============================================
# SECURITY NOTES:
# ============================================
# 1. Use strong database passwords (min 16 chars)
# 2. Use unique JWT secrets per environment
# 3. In production, use environment-specific secrets
# 4. Enable SSL in production database connections
# ============================================
